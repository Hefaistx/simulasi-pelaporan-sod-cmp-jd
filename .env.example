# Neon DB — POOLED connection (aktifkan "Connection pooling" di dashboard Neon)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"

# Neon DB — DIRECT connection (untuk prisma db push / migrate)
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# JWT secret — isi string random apapun, minimal 32 karakter
JWT_SECRET="ganti-ini-dengan-string-random-panjang-32char"
